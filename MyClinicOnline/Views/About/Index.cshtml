@{
    ViewData["Title"] = "About Us";
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-8">

            <div class="text-center mb-4">
                <h1 class="fw-bold">Welcome to MyClinicOnline</h1>
                <p class="text-muted fs-5">
                    Your trusted platform for finding and booking medical care.
                </p>
            </div>

            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <p class="fs-5">
                        <strong>MyClinicOnline</strong> is an online platform designed to help patients
                        easily find doctors, explore medical specialties, and book appointments
                        in a fast and convenient way.
                    </p>

                    <p>
                        We connect patients with qualified medical professionals, making healthcare
                        more accessible and transparent. Whether you are looking for a specialist,
                        a consultation, or reliable medical information, our goal is to simplify
                        the process and save you time.
                    </p>

                    <ul class="list-group list-group-flush my-4">
                        <li class="list-group-item">✔ Search doctors by specialty</li>
                        <li class="list-group-item">✔ View verified doctor profiles</li>
                        <li class="list-group-item">✔ Easy and fast appointment booking</li>
                        <li class="list-group-item">✔ Modern and user-friendly interface</li>
                    </ul>

                    <div class="text-center mt-4">
                        <a asp-controller="Home"
                           asp-action="Index"
                           class="btn btn-primary btn-lg">
                            Find a Doctor Now
                        </a>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>
