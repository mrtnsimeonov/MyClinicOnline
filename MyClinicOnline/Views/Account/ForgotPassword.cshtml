<div class="container mt-5" style="max-width: 400px;">
    <h2>Забравена парола</h2>
    <p class="text-muted small">Въведете имейла си и ще получите линк за нулиране на паролата.</p>

    @if (ViewBag.Message != null)
    {
        <div class="alert alert-success">@ViewBag.Message</div>
    }
    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger">@ViewBag.Error</div>
    }

    <form asp-action="ForgotPassword" method="post">
        <div class="mb-3">
            <label>Имейл</label>
            <input type="email" name="email" class="form-control" required />
        </div>
        <button type="submit" class="btn btn-primary w-100">Изпрати линк</button>
        <div class="mt-3 text-center">
            <a asp-action="Login" asp-controller="Account" class="text-muted small">Обратно към вход</a>
        </div>
    </form>
</div>
