@model RegisterDoctorViewModel
@{
    ViewData["Title"] = "Doctor Registration";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-lg border-0 rounded-4 p-4 backdrop-blur">
                <h2 class="fw-bold text-primary mb-4">Doctor Registration</h2>
                <form asp-action="RegisterDoctor" method="post">

                    <div class="mb-3">
                        <label class="form-label fw-bold">Full Name</label>
                        <input asp-for="FullName" class="form-control form-control-lg bg-light border-0" placeholder="Dr. Jane Doe" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Email Address</label>
                        <input asp-for="Email" class="form-control form-control-lg bg-light border-0" placeholder="doctor@clinic.com" />
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold">City of Operation</label>
                            <select asp-for="CityId" class="form-select bg-light border-0"
                                    asp-items="@(new SelectList(ViewBag.Cities, "Id", "Name"))">
                                <option value="">-- Select City --</option>
                            </select>
                        </div>
                        <div class="col-md-6 d-flex align-items-end">
                            <div class="form-check mb-2">
                                <input asp-for="WorksWithNhif" class="form-check-input" type="checkbox">
                                <label class="form-check-label fw-bold" asp-for="WorksWithNhif">Works with NHIF</label>
                            </div>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold">Select Specialties (Choose all that apply)</label>
                        <div class="row g-2 p-3 bg-light rounded-3">
                            @foreach (var specialty in (IEnumerable<Specialty>)ViewBag.Specialties)
                            {
                                <div class="col-md-4">
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" name="SelectedSpecialtyIds" value="@specialty.Id" id="spec_@specialty.Id">
                                        <label class="form-check-label" for="spec_@specialty.Id">@specialty.Name</label>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary btn-lg w-100 rounded-pill shadow">Complete Registration</button>
                </form>
            </div>
        </div>
    </div>
</div>