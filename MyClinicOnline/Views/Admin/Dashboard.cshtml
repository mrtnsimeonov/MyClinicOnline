@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container-fluid py-4 px-4">
    <div class="mb-4">
        <h2 class="fw-bold mb-0">Admin Dashboard</h2>
        <p class="text-muted">System overview — @DateTime.Now.ToString("dd MMMM yyyy")</p>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success rounded-3">@TempData["Success"]</div>
    }

    <!-- Stats row -->
    <div class="row g-3 mb-4">
        <div class="col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm rounded-4 p-4">
                <div class="d-flex align-items-center gap-3">
                    <div class="bg-primary bg-opacity-10 rounded-3 p-3">
                        <i class="bi bi-people-fill text-primary fs-4"></i>
                    </div>
                    <div>
                        <div class="fw-bold fs-3">@ViewBag.TotalPatients</div>
                        <div class="text-muted small">Total Patients</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm rounded-4 p-4">
                <div class="d-flex align-items-center gap-3">
                    <div class="bg-success bg-opacity-10 rounded-3 p-3">
                        <i class="bi bi-person-badge-fill text-success fs-4"></i>
                    </div>
                    <div>
                        <div class="fw-bold fs-3">@ViewBag.ApprovedDoctors</div>
                        <div class="text-muted small">Active Doctors</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm rounded-4 p-4">
                <div class="d-flex align-items-center gap-3">
                    <div class="bg-warning bg-opacity-10 rounded-3 p-3">
                        <i class="bi bi-hourglass-split text-warning fs-4"></i>
                    </div>
                    <div>
                        <div class="fw-bold fs-3">@ViewBag.PendingDoctors</div>
                        <div class="text-muted small">Pending Approval</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm rounded-4 p-4">
                <div class="d-flex align-items-center gap-3">
                    <div class="bg-info bg-opacity-10 rounded-3 p-3">
                        <i class="bi bi-calendar-check-fill text-info fs-4"></i>
                    </div>
                    <div>
                        <div class="fw-bold fs-3">@ViewBag.AppointmentsThisMonth</div>
                        <div class="text-muted small">Appointments This Month</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <!-- Online vs In-person -->
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 p-4 h-100">
                <h6 class="fw-bold mb-3">Consultation Types</h6>
                @{
                    int total = (int)ViewBag.TotalAppointments;
                    int online = (int)ViewBag.OnlineAppointments;
                    int inperson = (int)ViewBag.InPersonAppointments;
                    int onlinePct = total > 0 ? (int)((double)online / total * 100) : 0;
                    int inpersonPct = total > 0 ? 100 - onlinePct : 0;
                }
                <div class="mb-3">
                    <div class="d-flex justify-content-between mb-1">
                        <span class="small"><i class="bi bi-camera-video text-primary me-1"></i>Online</span>
                        <span class="small fw-bold">@online (@onlinePct%)</span>
                    </div>
                    <div class="progress rounded-pill" style="height: 8px;">
                        <div class="progress-bar bg-primary" style="width: @onlinePct%"></div>
                    </div>
                </div>
                <div>
                    <div class="d-flex justify-content-between mb-1">
                        <span class="small"><i class="bi bi-hospital text-secondary me-1"></i>In-person</span>
                        <span class="small fw-bold">@inperson (@inpersonPct%)</span>
                    </div>
                    <div class="progress rounded-pill" style="height: 8px;">
                        <div class="progress-bar bg-secondary" style="width: @inpersonPct%"></div>
                    </div>
                </div>
                <div class="mt-3 pt-3 border-top">
                    <div class="d-flex justify-content-between text-muted small">
                        <span>Total all time</span>
                        <strong class="text-dark">@total</strong>
                    </div>
                </div>
            </div>
        </div>

        <!-- Recent doctor registrations -->
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 p-4 h-100">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h6 class="fw-bold mb-0">Recent Doctor Registrations</h6>
                    <a asp-action="Doctors" class="btn btn-sm btn-outline-primary rounded-3">View All</a>
                </div>
                <table class="table table-sm table-hover mb-0">
                    <thead class="text-muted small">
                        <tr>
                            <th>Name</th>
                            <th>City</th>
                            <th>Status</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var d in ViewBag.RecentDoctors as List<MyClinicOnline.Models.Doctor>)
                        {
                            <tr>
                                <td class="align-middle fw-medium">@d.FullName</td>
                                <td class="align-middle text-muted small">@(d.City?.Name ?? "-")</td>
                                <td class="align-middle">
                                    @if (d.IsApproved)
                                    {
                                        <span class="badge bg-success bg-opacity-10 text-success rounded-pill">Approved</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning bg-opacity-10 text-warning rounded-pill">Pending</span>
                                    }
                                </td>
                                <td class="align-middle text-end">
                                    @if (!d.IsApproved)
                                    {
                                        <form asp-action="ApproveDoctor" method="post" class="d-inline">
                                            <input type="hidden" name="doctorId" value="@d.Id" />
                                            <button class="btn btn-sm btn-success rounded-3">Approve</button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Quick nav -->
    <div class="row g-3">
        <div class="col-6 col-md-3">
            <a asp-action="Doctors" class="card border-0 shadow-sm rounded-4 p-4 text-center text-decoration-none text-dark d-block hover-shadow">
                <i class="bi bi-person-badge-fill text-primary fs-2 mb-2 d-block"></i>
                <div class="fw-bold">Doctors</div>
            </a>
        </div>
        <div class="col-6 col-md-3">
            <a asp-action="Patients" class="card border-0 shadow-sm rounded-4 p-4 text-center text-decoration-none text-dark d-block">
                <i class="bi bi-people-fill text-success fs-2 mb-2 d-block"></i>
                <div class="fw-bold">Patients</div>
            </a>
        </div>
        <div class="col-6 col-md-3">
            <a asp-action="Specialties" class="card border-0 shadow-sm rounded-4 p-4 text-center text-decoration-none text-dark d-block">
                <i class="bi bi-tag-fill text-info fs-2 mb-2 d-block"></i>
                <div class="fw-bold">Specialties</div>
            </a>
        </div>
        <div class="col-6 col-md-3">
            <a asp-action="Cities" class="card border-0 shadow-sm rounded-4 p-4 text-center text-decoration-none text-dark d-block">
                <i class="bi bi-geo-alt-fill text-danger fs-2 mb-2 d-block"></i>
                <div class="fw-bold">Cities</div>
            </a>
        </div>
    </div>
</div>