@model IEnumerable<MyClinicOnline.Models.Doctor>
@{
    ViewData["Title"] = "Manage Doctors";
}

<div class="container-fluid py-4 px-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <a asp-action="Dashboard" class="text-decoration-none text-muted small">
                <i class="bi bi-arrow-left me-1"></i> Dashboard
            </a>
            <h2 class="fw-bold mt-1 mb-0">Manage Doctors</h2>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success rounded-3">@TempData["Success"]</div>
    }

    <!-- Pending approvals -->
    @{
        var pending = Model.Where(d => !d.IsApproved).ToList();
        var approved = Model.Where(d => d.IsApproved).ToList();
    }

    @if (pending.Any())
    {
        <div class="card border-0 border-start border-warning border-4 shadow-sm rounded-4 p-4 mb-4">
            <h5 class="fw-bold mb-3">
                <i class="bi bi-hourglass-split text-warning me-2"></i>
                Pending Approval (@pending.Count)
            </h5>
            <table class="table table-hover mb-0">
                <thead class="text-muted small">
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>City</th>
                        <th>Specialties</th>
                        <th>NHIF</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var d in pending)
                    {
                        <tr>
                            <td class="align-middle fw-medium">@d.FullName</td>
                            <td class="align-middle text-muted small">@d.Email</td>
                            <td class="align-middle text-muted small">@(d.City?.Name ?? "-")</td>
                            <td class="align-middle">
                                @string.Join(", ", d.Specialties.Select(s => s.Specialty?.Name ?? ""))
                            </td>
                            <td class="align-middle">
                                @if (d.WorksWithNhif)
                                {
                                    <i class="bi bi-check-circle-fill text-success"></i>
                                }
                                else
                                {
                                    <i class="bi bi-x-circle text-muted"></i>
                                }
                            </td>
                            <td class="align-middle">
                                <div class="d-flex gap-2">
                                    <form asp-action="ApproveDoctor" method="post">
                                        <input type="hidden" name="doctorId" value="@d.Id" />
                                        <button class="btn btn-sm btn-success rounded-3 fw-bold">
                                            <i class="bi bi-check-lg me-1"></i>Approve
                                        </button>
                                    </form>
                                    <form asp-action="RejectDoctor" method="post"
                                          onsubmit="return confirm('Reject and remove this doctor?')">
                                        <input type="hidden" name="doctorId" value="@d.Id" />
                                        <button class="btn btn-sm btn-outline-danger rounded-3">
                                            <i class="bi bi-x-lg me-1"></i>Reject
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    <!-- Approved doctors -->
    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-0">
            <div class="p-4 border-bottom">
                <h5 class="fw-bold mb-0">
                    <i class="bi bi-person-badge-fill text-primary me-2"></i>
                    Active Doctors (@approved.Count)
                </h5>
            </div>
            <table class="table table-hover mb-0">
                <thead class="bg-light text-muted small">
                    <tr>
                        <th class="px-4">Name</th>
                        <th>Email</th>
                        <th>City</th>
                        <th>Specialties</th>
                        <th>NHIF</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var d in approved)
                    {
                        <tr>
                            <td class="align-middle fw-medium px-4">@d.FullName</td>
                            <td class="align-middle text-muted small">@d.Email</td>
                            <td class="align-middle text-muted small">@(d.City?.Name ?? "-")</td>
                            <td class="align-middle small">
                                @string.Join(", ", d.Specialties.Select(s => s.Specialty?.Name ?? ""))
                            </td>
                            <td class="align-middle">
                                @if (d.WorksWithNhif)
                                {
                                    <i class="bi bi-check-circle-fill text-success"></i>
                                }
                                else
                                {
                                    <i class="bi bi-x-circle text-muted"></i>
                                }
                            </td>
                            <td class="align-middle">
                                <form asp-action="DeleteDoctor" method="post"
                                      onsubmit="return confirm('Delete Dr. @d.FullName? This cannot be undone.')">
                                    <input type="hidden" name="doctorId" value="@d.Id" />
                                    <button class="btn btn-sm btn-outline-danger rounded-3">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>