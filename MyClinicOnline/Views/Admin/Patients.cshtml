@model List<MyClinicOnline.Controllers.AdminPatientVm>
@{
    ViewData["Title"] = "Manage Patients";
}

<div class="container-fluid py-4 px-4">
    <div class="mb-4">
        <a asp-action="Dashboard" class="text-decoration-none text-muted small">
            <i class="bi bi-arrow-left me-1"></i> Dashboard
        </a>
        <h2 class="fw-bold mt-1 mb-0">Patients (@Model.Count)</h2>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success rounded-3">@TempData["Success"]</div>
    }

    <div class="card border-0 shadow-sm rounded-4">
        <table class="table table-hover mb-0">
            <thead class="bg-light text-muted small">
                <tr>
                    <th class="px-4">Name</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th>Region</th>
                    <th>Appointments</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model)
                {
                    <tr>
                        <td class="align-middle fw-medium px-4">@p.FirstName @p.LastName</td>
                        <td class="align-middle text-muted small">@p.Email</td>
                        <td class="align-middle text-muted small">@p.Phone</td>
                        <td class="align-middle text-muted small">@p.Region</td>
                        <td class="align-middle">
                            <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill">
                                @p.AppointmentCount
                            </span>
                        </td>
                        <td class="align-middle">
                            <form asp-action="DeletePatient" method="post"
                                  onsubmit="return confirm('Delete patient @p.FirstName @p.LastName?')">
                                <input type="hidden" name="patientId" value="@p.Id" />
                                <button class="btn btn-sm btn-outline-danger rounded-3">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>