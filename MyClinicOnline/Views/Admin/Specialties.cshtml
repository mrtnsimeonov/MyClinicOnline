@model IEnumerable<MyClinicOnline.Models.Specialty>
@{
    ViewData["Title"] = "Manage Specialties";
}

<div class="container py-4" style="max-width: 700px;">
    <div class="mb-4">
        <a asp-action="Dashboard" class="text-decoration-none text-muted small">
            <i class="bi bi-arrow-left me-1"></i> Dashboard
        </a>
        <h2 class="fw-bold mt-1 mb-0">Specialties</h2>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success rounded-3">@TempData["Success"]</div>
    }

    <!-- Add form -->
    <div class="card border-0 shadow-sm rounded-4 p-4 mb-4">
        <h6 class="fw-bold mb-3">Add New Specialty</h6>
        <form asp-action="AddSpecialty" method="post" class="d-flex gap-2">
            <input name="name" class="form-control rounded-3" placeholder="e.g. Ophthalmology" required />
            <button type="submit" class="btn btn-primary rounded-3 fw-bold px-4">Add</button>
        </form>
    </div>

    <!-- List -->
    <div class="card border-0 shadow-sm rounded-4">
        <table class="table table-hover mb-0">
            <thead class="bg-light text-muted small">
                <tr>
                    <th class="px-4">Specialty</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var s in Model)
                {
                    <tr>
                        <td class="align-middle fw-medium px-4">@s.Name</td>
                        <td class="align-middle">
                            <form asp-action="DeleteSpecialty" method="post"
                                  onsubmit="return confirm('Delete @s.Name?')">
                                <input type="hidden" name="specialtyId" value="@s.Id" />
                                <button class="btn btn-sm btn-outline-danger rounded-3">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>