@model IEnumerable<MyClinicOnline.Models.Doctor>

@{
    ViewData["Title"] = "Available Doctors";
}

<div class="container py-5">
    <div class="mb-5">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-2">
                <li class="breadcrumb-item"><a asp-controller="Booking" asp-action="Index" class="text-decoration-none">Booking</a></li>
                <li class="breadcrumb-item active">Available Doctors</li>
            </ol>
        </nav>
        <h2 class="fw-bold text-dark display-6">Available Specialists</h2>
        <div class="d-flex gap-3 text-muted">
            <span><i class="bi bi-tag me-1"></i> <strong>@ViewBag.Specialty</strong></span>
            <span><i class="bi bi-geo-alt me-1"></i> <strong>@ViewBag.City</strong></span>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="card border-0 shadow-sm rounded-4 p-5 text-center bg-white">
            <div class="py-4">
                <i class="bi bi-calendar-x text-muted display-1 mb-4"></i>
                <h3 class="fw-bold">No availability found</h3>
                <p class="text-secondary">Try selecting a different city or specialty.</p>
                <a asp-action="Index" class="btn btn-outline-primary px-4 mt-2">Change Search</a>
            </div>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var d in Model)
            {
                <div class="col-12">
                    <div class="card border-0 shadow-sm rounded-4 overflow-hidden result-card transition-all">
                        <div class="card-body p-4">
                            <div class="row align-items-center">
                                <div class="col-auto">
                                    <div class="bg-primary bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center" style="width: 85px; height: 85px;">
                                        <i class="bi bi-person-check-fill text-primary" style="font-size: 2.5rem;"></i>
                                    </div>
                                </div>

                                <div class="col px-md-4">
                                    <div class="d-flex align-items-center mb-1 flex-wrap gap-2">
                                        <h4 class="fw-bold mb-0 text-dark">@d.FullName</h4>
                                        @if (d.WorksWithNhif)
                                        {
                                            <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 rounded-pill small">
                                                <i class="bi bi-shield-check me-1"></i> NHIF Verified
                                            </span>
                                        }
                                    </div>

                                    <p class="text-primary fw-medium mb-3">
                                        @string.Join(", ", d.Specialties.Select(x => x.Specialty.Name))
                                    </p>

                                    <div class="d-flex flex-wrap gap-4 text-muted small">
                                        <span class="d-flex align-items-center"><i class="bi bi-geo-alt me-1 text-danger"></i> @(d.City?.Name ?? "N/A")</span>
                                        <span class="d-flex align-items-center"><i class="bi bi-star-fill me-1 text-warning"></i> 4.8 (Verified)</span>
                                    </div>
                                </div>

                                <div class="col-md-3 text-md-end mt-3 mt-md-0 border-start ps-md-4">
                                    <a class="btn btn-primary w-100 py-3 fw-bold rounded-3 shadow-sm"
                                       asp-controller="Calendar"
                                       asp-action="Index"
                                       asp-route-doctorId="@d.Id">
                                        Select Time Slot <i class="bi bi-calendar-plus ms-2"></i>
                                    </a>
                                    <p class="small text-muted mt-2 mb-0 text-center">No booking fees</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>