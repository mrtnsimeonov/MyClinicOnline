@model MyClinicOnline.Controllers.CalendarVm
@using System.Globalization
@using System.Text.Json

@{
    ViewData["Title"] = "Calendar";

    var monthStart = new DateTime(Model.Month.Year, Model.Month.Month, 1);
    var monthEnd = monthStart.AddMonths(1).AddDays(-1);

    // day slots map: "yyyy-MM-dd" -> list of slots
    var dayMap = Model.Slots
        .GroupBy(s => s.StartTime.Date)
        .ToDictionary(
            g => g.Key.ToString("yyyy-MM-dd"),
            g => g.OrderBy(x => x.StartTime).Select(x => new
            {
                id = x.Id,
                time = x.StartTime.ToString("HH:mm"),
                booked = x.IsBooked
            }).ToList()
        );

    var json = JsonSerializer.Serialize(dayMap);

    // Calendar grid helpers
    int daysInMonth = DateTime.DaysInMonth(monthStart.Year, monthStart.Month);
    int firstDayOfWeek = (int)monthStart.DayOfWeek; // Sunday=0
    int offset = (firstDayOfWeek + 6) % 7; // Monday first
}

<div class="container my-5">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h2 class="fw-bold mb-0">@Model.DoctorName</h2>
            <div class="text-muted">
                @if (!string.IsNullOrWhiteSpace(Model.CityName))
                {
                    <span>@Model.CityName</span>
                }
            </div>
        </div>

        <div class="d-flex gap-2">
            @{
                var prev = monthStart.AddMonths(-1);
                bool canPrev = prev >= Model.MinMonth;
                var next = monthStart.AddMonths(1);
                bool canNext = next <= Model.MaxMonth;
            }

            <a class="btn btn-outline-secondary @(canPrev ? "" : "disabled")"
               asp-action="Index"
               asp-route-doctorId="@Model.DoctorId"
               asp-route-year="@prev.Year"
               asp-route-month="@prev.Month">
                ←
            </a>

            <span class="btn btn-light border">
                @monthStart.ToString("MMMM yyyy", CultureInfo.InvariantCulture)
            </span>

            <a class="btn btn-outline-secondary @(canNext ? "" : "disabled")"
               asp-action="Index"
               asp-route-doctorId="@Model.DoctorId"
               asp-route-year="@next.Year"
               asp-route-month="@next.Month">
                →
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="row g-3">
        <div class="col-lg-8">
            <div class="card shadow-sm">
                <div class="card-body p-3">

                    <div class="row text-center fw-semibold mb-2">
                        <div class="col">Mon</div>
                        <div class="col">Tue</div>
                        <div class="col">Wed</div>
                        <div class="col">Thu</div>
                        <div class="col">Fri</div>
                        <div class="col">Sat</div>
                        <div class="col">Sun</div>
                    </div>

                    <div class="row row-cols-7 g-2">
                        @for (int i = 0; i < offset; i++)
                        {
                            <div class="col">
                                <div class="border rounded p-3 bg-light" style="height:70px;"></div>
                            </div>
                        }

                        @for (int day = 1; day <= daysInMonth; day++)
                        {
                            var date = new DateTime(monthStart.Year, monthStart.Month, day);
                            var key = date.ToString("yyyy-MM-dd");
                            bool isPast = date.Date < DateTime.Today;

                            <div class="col">
                                <button type="button"
                                        class="w-100 border rounded p-2 text-start @(isPast ? "bg-light" : "bg-white")"
                                        style="height:70px;"
                                        onclick="selectDay('@key')"
                                @(isPast ? "disabled" : "")>
                                    <div class="fw-bold">@day</div>
                                    <div class="text-muted" style="font-size:12px;">
                                        @date.ToString("ddd", CultureInfo.InvariantCulture)
                                    </div>
                                </button>
                            </div>
                        }
                    </div>

                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <h5 class="fw-bold">Choose hour</h5>
                    <p class="text-muted mb-3">Select a day to see available hours.</p>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Selected day</label>
                        <input id="selectedDay" class="form-control" readonly />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Available hours</label>
                        <select id="hoursSelect" class="form-select" disabled></select>
                        <div class="form-text">Booked hours appear in red and cannot be selected.</div>
                    </div>

                    <form asp-action="Book" method="post" id="bookingForm">
                        <input type="hidden" name="slotId" id="slotId" />
                        <button id="bookBtn" class="btn btn-primary w-100" type="button" disabled onclick="handleBooking()">
                            Book / Запази
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const dayMap = @Html.Raw(json);
        const isAuthenticated = @User.Identity.IsAuthenticated.ToString().ToLower();

        //  This function handles your popup check
        function handleBooking() {
            if (!isAuthenticated) {
                alert("You need to be logged in to book an hour.");
            } else {
                document.getElementById("bookingForm").submit();
            }
        }

        function selectDay(key) {
            document.getElementById("selectedDay").value = key;

            const select = document.getElementById("hoursSelect");
            const bookBtn = document.getElementById("bookBtn");
            const slotIdInput = document.getElementById("slotId");

            select.innerHTML = "";
            slotIdInput.value = "";
            bookBtn.disabled = true;

            const slots = dayMap[key] || [];
            if (slots.length === 0) {
                select.disabled = true;
                const opt = document.createElement("option");
                opt.textContent = "No working hours";
                select.appendChild(opt);
                return;
            }

            select.disabled = false;

            const first = document.createElement("option");
            first.value = "";
            first.textContent = "-- Select hour --";
            select.appendChild(first);

            slots.forEach(s => {
                const opt = document.createElement("option");
                opt.value = s.id;
                opt.textContent = s.time;

                if (s.booked) {
                    opt.disabled = true;
                    opt.style.backgroundColor = "#f8d7da";
                    opt.style.color = "#000";
                }

                select.appendChild(opt);
            });

            select.onchange = () => {
                const chosen = select.value;
                slotIdInput.value = chosen;
                bookBtn.disabled = !chosen;
            };
        }
    </script>
}