@model IEnumerable<MyClinicOnline.Models.TimeSlot>
@{
    var appointments = ViewBag.Appointments as Dictionary<int, MyClinicOnline.Models.User>;
}

<div class="container mt-5">
    <h2 class="fw-bold mb-4">Your Schedule</h2>
    <div class="card shadow border-0">
        <table class="table table-hover mb-0">
            <thead class="bg-light">
                <tr>
                    <th>Date & Time</th>
                    <th>Status</th>
                    <th>Patient</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var slot in Model)
                {
                    <tr>
                        <td>@slot.StartTime.ToString("dd.MM.yyyy HH:mm")</td>
                        <td>
                            <span class="badge @(slot.IsBooked ? "bg-danger" : "bg-success")">
                                @(slot.IsBooked ? "Booked" : "Available")
                            </span>
                        </td>
                        <td>
                            @if (slot.IsBooked && appointments != null && appointments.ContainsKey(slot.Id))
                            {
                                @($"{appointments[slot.Id].FirstName} {appointments[slot.Id].LastName}")
                            }
                            else
                            {
                                <span>-</span>
                            }
                        </td>
                        <td>
                            @if (slot.IsBooked)
                            {
                                <form asp-action="CancelBooking" method="post">
                                    <input type="hidden" name="slotId" value="@slot.Id" />
                                    <button class="btn btn-sm btn-outline-danger">Cancel & Notify</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>