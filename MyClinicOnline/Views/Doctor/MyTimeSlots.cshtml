@model IEnumerable<MyClinicOnline.Models.TimeSlot>
@using MyClinicOnline.Models
@{
    ViewData["Title"] = "My Schedule";
    var appointments = ViewBag.Appointments as Dictionary<int, Appointment>;
}

<div class="container mt-5">
    <h2 class="fw-bold mb-4">Your Schedule</h2>
    <div class="card shadow border-0">
        <table class="table table-hover mb-0">
            <thead class="bg-light">
                <tr>
                    <th>Date &amp; Time</th>
                    <th>Status</th>
                    <th>Type</th>
                    <th>Patient</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var slot in Model)
                {
                    var appt = (appointments != null && appointments.ContainsKey(slot.Id))
                    ? appointments[slot.Id]
                    : null;

                    <tr>
                        <td class="align-middle">@slot.StartTime.ToString("dd.MM.yyyy HH:mm")</td>
                        <td class="align-middle">
                            <span class="badge @(slot.IsBooked ? "bg-danger" : "bg-success")">
                                @(slot.IsBooked ? "Booked" : "Available")
                            </span>
                        </td>
                        <td class="align-middle">
                            @if (appt != null)
                            {
                                if (appt.ConsultationType == ConsultationType.Online)
                                {
                                    <span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25 rounded-pill">
                                        <i class="bi bi-camera-video me-1"></i> Online
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary border-opacity-25 rounded-pill">
                                        <i class="bi bi-hospital me-1"></i> In-person
                                    </span>
                                }
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </td>
                        <td class="align-middle">
                            @if (appt != null)
                            {
                                @($"{appt.User.FirstName} {appt.User.LastName}")
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </td>
                        <td class="align-middle">
                            <div class="d-flex gap-2">
                                @if (appt != null && appt.ConsultationType == ConsultationType.Online && appt.MeetingCode != null)
                                {
                                    <a href="/Video/Join?code=@appt.MeetingCode" target="_blank"
                                       class="btn btn-sm btn-success">
                                        <i class="bi bi-camera-video me-1"></i> Join
                                    </a>
                                }
                                @if (slot.IsBooked)
                                {
                                    <form asp-action="CancelBooking" method="post">
                                        <input type="hidden" name="slotId" value="@slot.Id" />
                                        <button class="btn btn-sm btn-outline-danger">Cancel &amp; Notify</button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>