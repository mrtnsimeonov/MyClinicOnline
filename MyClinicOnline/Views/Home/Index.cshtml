@{
    ViewData["Title"] = "Home";
}

<style>
    .home-hero-wrapper {
        background: radial-gradient(circle at top right, #e9f5ff 0%, #ffffff 50%), linear-gradient(135deg, #f0f7ff 0%, #e0edff 100%);
        position: relative;
        overflow: hidden;
        min-height: 85vh;
        display: flex;
        align-items: center;
    }

        /* Consistent grid pattern */
        .home-hero-wrapper::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-image: linear-gradient(#4a90e212 1px, transparent 1px), linear-gradient(90deg, #4a90e212 1px, transparent 1px);
            background-size: 40px 40px;
            z-index: 0;
        }

    .backdrop-blur {
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        background: rgba(255, 255, 255, 0.8) !important;
        border: 1px solid rgba(255, 255, 255, 0.3) !important;
    }

    .search-card {
        transition: all 0.3s ease;
        border: 1px solid rgba(0,0,0,0.05);
    }

        .search-card:focus-within {
            transform: translateY(-2px);
            box-shadow: 0 15px 30px rgba(0, 102, 255, 0.1) !important;
        }
</style>

<div class="home-hero-wrapper">
    <div class="container position-relative" style="z-index: 2;">
        <div class="row align-items-center">
            <div class="col-lg-7 py-5">
                <span class="badge rounded-pill bg-primary bg-opacity-10 text-primary px-3 py-2 mb-3 fw-bold">
                    <i class="bi bi-shield-check me-1"></i> Trusted by 10,000+ Patients
                </span>
                <h1 class="display-3 fw-bold text-dark mb-3" style="letter-spacing: -1px;">
                    Your Health, <span class="text-primary">Simplified.</span>
                </h1>
                <p class="lead text-secondary mb-5 fs-4">
                    Access top-tier medical care with instant booking and remote consultations.
                </p>

                <div class="search-card bg-white p-2 rounded-4 shadow-lg mb-4">
                    <form asp-controller="Doctor" asp-action="Search" method="get" class="row g-0 align-items-center">
                        <div class="col-md-5 px-3 border-end">
                            <label class="small fw-bold text-muted d-block text-uppercase mb-1" style="font-size: 0.65rem;">Specialty</label>
                            <div class="d-flex align-items-center">
                                <i class="bi bi-search text-primary me-2"></i>
                                <input type="text" name="specialty" class="form-control border-0 p-0 shadow-none bg-transparent" placeholder="e.g. Cardiologist" required />
                            </div>
                        </div>
                        <div class="col-md-4 px-3">
                            <label class="small fw-bold text-muted d-block text-uppercase mb-1" style="font-size: 0.65rem;">Location</label>
                            <div class="d-flex align-items-center">
                                <i class="bi bi-geo-alt text-primary me-2"></i>
                                <input type="text" name="city" class="form-control border-0 p-0 shadow-none bg-transparent" placeholder="City or Region" />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <button type="submit" class="btn btn-primary w-100 py-3 rounded-3 fw-bold">
                                Find Care
                            </button>
                        </div>
                    </form>
                </div>

                <div class="d-flex align-items-center gap-3">
                    <a asp-controller="Booking" asp-action="Index" class="btn btn-dark px-4 py-2 fw-bold rounded-3 shadow">
                        <i class="bi bi-calendar-plus me-2"></i>Book Now
                    </a>
                    <a asp-controller="Account" asp-action="RegisterDoctor" class="btn btn-link text-decoration-none text-primary fw-bold">
                        Register as Doctor <i class="bi bi-arrow-right ms-1"></i>
                    </a>
                </div>
            </div>

            <div class="col-lg-5 d-none d-lg-block">
                <div class="card border-0 shadow-lg rounded-5 p-4 backdrop-blur">
                    <div class="d-flex align-items-center mb-4">
                        <div class="flex-shrink-0 bg-primary bg-gradient p-3 rounded-4 text-white shadow-sm">
                            <i class="bi bi-person-pulse fs-1"></i>
                        </div>
                        <div class="ms-3">
                            <h5 class="mb-0 fw-bold text-dark">Quick Appointment</h5>
                            <p class="small text-muted mb-0">Manage your health in one click.</p>
                        </div>
                    </div>
                    <ul class="list-unstyled mb-0">
                        <li class="mb-2 d-flex align-items-center small"><i class="bi bi-check-circle-fill text-success me-2"></i> 24/7 Support</li>
                        <li class="mb-2 d-flex align-items-center small"><i class="bi bi-check-circle-fill text-success me-2"></i> Video Consultations</li>
                        <li class="d-flex align-items-center small"><i class="bi bi-check-circle-fill text-success me-2"></i> Verified Doctors</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>