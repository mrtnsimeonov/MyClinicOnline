@{
    ViewData["Title"] = "Home";
}

<div class="hero-container overflow-hidden position-relative pt-4 pb-0" style="background: #fcfcfd;">
    <div class="container position-relative" style="z-index: 2;">
        <div class="row align-items-center min-vh-75">
            <div class="col-lg-7 py-5">
                <span class="badge rounded-pill bg-primary bg-opacity-10 text-primary px-3 py-2 mb-3 fw-bold">
                    <i class="bi bi-shield-check me-1"></i> Trusted by 10,000+ Patients
                </span>
                <h1 class="display-3 fw-extrabold text-dark mb-3 tracking-tight" style="font-weight: 800;">
                    Your Health, <span class="text-primary">Simplified.</span>
                </h1>
                <p class="lead text-secondary mb-5 fs-4">
                    Access top-tier medical care with instant booking and remote consultations.
                </p>

                <div class="search-card bg-white p-2 rounded-4 shadow-xl border mb-4">
                    <form asp-controller="Doctors" asp-action="Search" method="get" class="row g-0 align-items-center">
                        <div class="col-md-5 px-3 border-end">
                            <label class="small fw-bold text-muted d-block text-uppercase mb-1" style="font-size: 0.65rem;">Specialty</label>
                            <div class="d-flex align-items-center">
                                <i class="bi bi-search text-primary me-2"></i>
                                <input type="text" name="specialty" class="form-control border-0 p-0 shadow-none bg-transparent" placeholder="e.g. Cardiologist" required />
                            </div>
                        </div>
                        <div class="col-md-4 px-3">
                            <label class="small fw-bold text-muted d-block text-uppercase mb-1" style="font-size: 0.65rem;">Location</label>
                            <div class="d-flex align-items-center">
                                <i class="bi bi-geo-alt text-primary me-2"></i>
                                <input type="text" name="city" class="form-control border-0 p-0 shadow-none bg-transparent" placeholder="City or Region" />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <button type="submit" class="btn btn-primary w-100 py-3 rounded-3 fw-bold shadow-sm">
                                Find Care
                            </button>
                        </div>
                    </form>
                </div>

                <div class="d-flex align-items-center gap-3">
                    <a asp-controller="Booking" asp-action="Index" class="btn btn-dark px-4 py-2 fw-bold rounded-3 shadow-sm">
                        <i class="bi bi-calendar-plus me-2"></i>Book Now
                    </a>
                    <a href="#register" class="btn btn-link text-decoration-none text-primary fw-bold">
                        Register as Doctor <i class="bi bi-arrow-right ms-1"></i>
                    </a>
                </div>
            </div>

            <div class="col-lg-5 d-none d-lg-block">
                <div class="card border-0 shadow-lg rounded-5 p-4 bg-white bg-opacity-75 backdrop-blur border border-white">
                    <div class="d-flex align-items-center mb-4">
                        <div class="flex-shrink-0 bg-primary bg-gradient p-3 rounded-4 text-white shadow">
                            <i class="bi bi-person-pulse fs-1"></i>
                        </div>
                        <div class="ms-3">
                            <h5 class="mb-0 fw-bold text-dark">Quick Appointment</h5>
                            <p class="small text-muted mb-0">Manage your health in one click.</p>
                        </div>
                    </div>
                    <ul class="list-unstyled mb-0">
                        <li class="mb-2 d-flex align-items-center small"><i class="bi bi-check-circle-fill text-success me-2"></i> 24/7 Support</li>
                        <li class="mb-2 d-flex align-items-center small"><i class="bi bi-check-circle-fill text-success me-2"></i> Video Consultations</li>
                        <li class="d-flex align-items-center small"><i class="bi bi-check-circle-fill text-success me-2"></i> Verified Doctors</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* Corporate Visual Refinements */
    :root {
        --bs-primary: #0066FF;
    }

    body {
        background-color: #fcfcfd;
        font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
    }

    .shadow-xl {
        box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.05), 0 10px 10px -5px rgba(0, 0, 0, 0.02) !important;
    }

    .backdrop-blur {
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
    }

    .search-card {
        transition: all 0.2s ease-in-out;
        border: 1px solid #eef0f2;
    }

        .search-card:focus-within {
            border-color: var(--bs-primary) !important;
            box-shadow: 0 0 0 4px rgba(0, 102, 255, 0.1) !important;
        }

    .btn-dark {
        background-color: #1a1d21;
        border: none;
    }

        .btn-dark:hover {
            background-color: #000;
            transform: translateY(-1px);
        }

    .min-vh-75 {
        min-height: 75vh;
    }

    main.pb-3 {
        padding-bottom: 0 !important;
    }
</style>