<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MyClinicOnline</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/home.css" />
    <link rel="stylesheet" href="~/MyClinicOnline.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom shadow-sm mb-3 py-3">
            <div class="container">
                <a class="navbar-brand fw-bold text-primary d-flex align-items-center" asp-area="" asp-controller="Home" asp-action="Index" style="letter-spacing: -0.5px;">
                    <i class="bi bi-heart-pulse-fill me-2"></i>MyClinicOnline
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1 justify-content-center">
                        <li class="nav-item">
                            <a class="nav-link text-dark mx-2 fw-medium" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark mx-2 fw-medium" asp-controller="About" asp-action="Index">About</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark mx-2 fw-medium" asp-controller="Contact" asp-action="Index">Contact</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark mx-2 fw-medium" asp-controller="Home" asp-action="Privacy">Privacy</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark mx-2 fw-medium" asp-controller="Video" asp-action="Join">
                                <i class="bi bi-camera-video me-1"></i> Join Meeting
                            </a>
                        </li>
                    </ul>

                    <div class="d-flex align-items-center">
                        @if (User.Identity.IsAuthenticated)
                        {
                            var initials = User.FindFirst("Initials")?.Value;
                            var isDoctor = User.IsInRole("Doctor");
                            var isPatient = User.IsInRole("Patient"); // We'll use this for the check

                            <div class="dropdown">
                                <button class="btn btn-white shadow-sm border rounded-pill px-3 py-1 dropdown-toggle d-flex align-items-center gap-2"
                                        type="button" id="userMenu" data-bs-toggle="dropdown" aria-expanded="false" style="transition: all 0.3s ease;">
                                    <div class="bg-primary bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center text-primary fw-bold"
                                         style="width: 32px; height: 32px; font-size: 0.85rem;">
                                        @initials
                                    </div>
                                    <span class="fw-bold text-dark small">Account</span>
                                </button>

                                <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0 rounded-4 mt-2 p-2" aria-labelledby="userMenu" style="min-width: 240px;">
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <li>
                                            <a class="dropdown-item rounded-3 py-2 d-flex align-items-center profile-link"
                                               asp-controller="Admin" asp-action="Dashboard">
                                                <i class="bi bi-shield-lock-fill text-danger me-2 fs-5"></i>
                                                <div>
                                                    <span class="d-block fw-bold text-dark" style="font-size: 0.9rem;">Admin Panel</span>
                                                    <small class="text-muted" style="font-size: 0.7rem;">Manage the system</small>
                                                </div>
                                            </a>
                                        </li>
                                        <li><hr class="dropdown-divider mx-2"></li>
                                    }
                                    @if (isDoctor)
                                    {
                                        <li>
                                            <a class="dropdown-item rounded-3 py-2 d-flex align-items-center profile-link" asp-controller="Doctor" asp-action="MyTimeSlots">
                                                <i class="bi bi-calendar-week text-primary me-2 fs-5"></i>
                                                <div>
                                                    <span class="d-block fw-bold text-dark" style="font-size: 0.9rem;">My Timeslots</span>
                                                    <small class="text-muted" style="font-size: 0.7rem;">Manage availability</small>
                                                </div>
                                            </a>
                                        </li>
                                    }

                                    @if (isPatient) // ONLY SHOWS FOR PATIENTS
                                    {
                                        <li>
                                            <a class="dropdown-item rounded-3 py-2 d-flex align-items-center profile-link" asp-controller="Booking" asp-action="MyAppointments">
                                                <i class="bi bi-calendar-check text-primary me-2 fs-5"></i>
                                                <div>
                                                    <span class="d-block fw-bold text-dark" style="font-size: 0.9rem;">
                                                        Моите Часове
                                                        <span class="unread-badge badge bg-danger rounded-pill ms-1" style="display:none; font-size:0.65rem;"></span>
                                                    </span>
                                                    <small class="text-muted" style="font-size: 0.7rem;">Manage your bookings</small>
                                                </div>
                                            </a>
                                        </li>
                                    }

                                    <li><hr class="dropdown-divider mx-2"></li>

                                    <li>
                                        <a class="dropdown-item rounded-3 py-2 d-flex align-items-center profile-link-logout" asp-controller="Account" asp-action="Logout">
                                            <i class="bi bi-box-arrow-right text-danger me-2 fs-5"></i>
                                            <span class="fw-bold text-danger" style="font-size: 0.9rem;">Изход</span>
                                        </a>
                                    </li>
                                </ul>
                            </div>
                        }
                        else
                        {
                            <a class="btn btn-outline-primary me-2 px-4 fw-bold rounded-pill" asp-controller="Account" asp-action="Login">Вход</a>
                            <a class="btn btn-primary px-4 shadow-sm fw-bold rounded-pill" asp-controller="Account" asp-action="Register">Регистрация</a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="container-fluid p-0">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted bg-light py-4">
        <div class="container text-center">
            <p class="mb-0">&copy; 2025 - <span class="text-primary fw-bold">MyClinicOnline</span> - <a asp-area="" asp-controller="Home" asp-action="Privacy" class="text-decoration-none">Privacy Policy</a></p>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
    @if (User.Identity.IsAuthenticated)
    {
        <script>
            async function checkUnread() {
                try {
                    const res = await fetch('/Messages/UnreadCount');
                    const count = await res.json();
                    document.querySelectorAll('.unread-badge').forEach(badge => {
                        if (count > 0) {
                            badge.textContent = count;
                            badge.style.display = 'inline';
                        } else {
                            badge.style.display = 'none';
                        }
                    });
                } catch {}
            }
            checkUnread();
            setInterval(checkUnread, 30000);
        </script>
    }
</body>
</html>